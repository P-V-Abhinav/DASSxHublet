# ── Database (SQLite via Prisma) ──────────────────────────────────────────────
# Local dev:   DATABASE_URL="file:./dev.db"
# Render prod: DATABASE_URL="file:./dev.db"  (or mount a persistent disk)
DATABASE_URL="file:./dev.db"

# ── Server ────────────────────────────────────────────────────────────────────
PORT=3000
# NODE_ENV=development  (local)
# NODE_ENV=production   (Render)
NODE_ENV=development

# ── JWT Auth ────────────────────────────────────────────────────────────────
JWT_SECRET=replace_with_a_long_random_secret
JWT_EXPIRES_IN=24h
# Backward-compatible alias (typo) supported by code:
# JWT_EXPRESS_IN=24h

# ── Admin Auth ──────────────────────────────────────────────────────────────
ADMIN_EMAIL=hublet@iiit.ac.in
ADMIN_PASSWORD=admin123

# ── Buyer/Seller Super Password (fallback login) ───────────────────────────
SUPER_PASSWORD=replace_with_shared_super_password

# Public-facing URL of this backend (used in startup logs and utility scripts)
# BASE_URL=http://localhost:3000              (local)
# BASE_URL=https://project-monorepo-team-46.onrender.com  (production)
BASE_URL=http://localhost:3000

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins.
# CORS_ORIGIN=http://localhost:5173                                       (local dev)
# CORS_ORIGIN=https://dass-hublet-frontend.vercel.app,*.vercel.app,http://localhost:5173  (prod + all Vercel previews + local)
CORS_ORIGIN=http://localhost:5173  # dev only; for prod use the line above

# ── MongoDB Atlas ─────────────────────────────────────────────────────────────
MONGODB_URI="mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?appName=Cluster0"
MONGODB_DB_NAME="hublet"

# ── Scrapers ──────────────────────────────────────────────────────────────────
APIFY_TOKEN=your_apify_token_here
APIFY_TOKEN_FB=your_apify_token_here
# Required for Facebook scraper: single actor ID/slug
# Example: APIFY_ACTOR_ID_FB=yourname/facebook-groups-scraper
APIFY_ACTOR_ID_FB=your_actor_id_or_slug
FB_RESULTS_LIMIT=20
FB_VIEW_OPTION=CHRONOLOGICAL
ZENROWS_API_KEY=your_zenrows_api_key_here
SCRAPER=99acres-apify

# ── Groq (LLM extraction) ────────────────────────────────────────────────────
GROQ_API_KEY=your_groq_key_here
GROQ_API_KEY_1=your_groq_key_here_1
GROQ_API_KEY_2=your_groq_key_here_2
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile
FB_LLM_TEMPERATURE=0
FB_API_DELAY_SECONDS=1

# ── Internal utility scripts ──────────────────────────────────────────────────
# Used by generate-all-matches.js
# API_BASE_URL=http://localhost:3000                                       (local)
# API_BASE_URL=https://project-monorepo-team-46.onrender.com              (production)
API_BASE_URL=http://localhost:3000
